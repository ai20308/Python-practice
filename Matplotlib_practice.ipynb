   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "day = np.arange(365)\n",
    "hours = 4.276 * np.sin(2 * np.pi * (day - 80)/365) + 12.203\n",
    "\n",
    "fig, ax = plt.subplots()\n",
    "ax.plot(day, hours, color=\"orange\")\n",
    "ax.set_xlabel(\"day\")\n",
    "ax.set_ylabel(\"daylight hours\")\n",
    "ax.set_title(\"London\")\n",
    "plt.show()"
   ]
  },
